---
import Layout from '../layouts/Layout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const recipes = await getCollection('recipes');
const allDishes = recipes
  .filter((r) => !r.data.tags.includes('filler'))
  .map((r) => ({
    id: r.id,
    title: r.data.title,
    image: r.data.image,
    description: r.data.description,
    tags: r.data.tags,
    rating: r.data.rating,
    category: r.data.tags.find((t) => ['main', 'side'].includes(t)),
    href: `${base}recipes/${r.id}/`,
    isMain: r.data.tags.includes('main'),
  }));
---

<Layout title="Surprise me">
  <div class="random-page">
    <h1>Can't decide?</h1>
    <p class="subtitle">Here are some picks for you.</p>

    <div class="picks photo-grid" id="picks">
      {allDishes.map((dish) => (
        <div class="pick-item" data-id={dish.id} data-main={dish.isMain ? 'true' : 'false'}>
          <RecipeCard
            title={dish.title}
            image={dish.image}
            href={dish.href}
            description={dish.description}
            tags={dish.tags}
            rating={dish.rating}
            category={dish.category}
          />
        </div>
      ))}
    </div>

    <button id="shuffle-btn" class="shuffle-btn">Show me different dishes</button>
  </div>
</Layout>

<script>
  const items = Array.from(document.querySelectorAll<HTMLElement>('.pick-item'));
  const btn = document.getElementById('shuffle-btn')!;
  const VISIBLE_COUNT = 3;

  function pickRandom<T>(arr: T[]): T {
    return arr[Math.floor(Math.random() * arr.length)];
  }

  function shuffle() {
    const mains = items.filter((c) => c.dataset.main === 'true');
    const picked = new Set<HTMLElement>();

    if (mains.length > 0) picked.add(pickRandom(mains));

    const remaining = items.filter((c) => !picked.has(c));
    while (picked.size < Math.min(VISIBLE_COUNT, items.length)) {
      picked.add(pickRandom(remaining.filter((c) => !picked.has(c))));
    }

    items.forEach((item) => {
      item.style.display = picked.has(item) ? '' : 'none';
    });
  }

  shuffle();
  btn.addEventListener('click', shuffle);
</script>

<style>
  .random-page {
    text-align: center;
  }

  .random-page h1 {
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--color-muted);
    margin-bottom: 2rem;
  }

  .shuffle-btn {
    margin-top: 2rem;
    padding: 0.8rem 2rem;
    font-size: 1rem;
    font-family: var(--font-body);
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .shuffle-btn:hover {
    background: #a84830;
  }
</style>
