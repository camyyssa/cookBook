---
import Layout from '../layouts/Layout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const recipes = await getCollection('recipes');
const inspiration = await getCollection('inspiration');
const allItems = [
  ...recipes.map((r) => ({
    id: r.id,
    title: r.data.title,
    image: r.data.image,
    description: r.data.description,
    tags: r.data.tags,
    rating: r.data.rating,
    category: r.data.tags.find((t) => ['main', 'side', 'staple'].includes(t)),
    href: `${base}recipes/${r.id}/`,
  })),
  ...inspiration.map((i) => ({
    id: i.id,
    title: i.data.title,
    image: i.data.image,
    description: undefined,
    tags: i.data.tags,
    rating: undefined,
    category: undefined,
    href: `${base}inspiration/`,
  })),
];
---

<Layout title="Home">
  <section class="hero">
    <h1>What are we cooking today?</h1>
    <p>Browse recipes, get inspired, or <a href={`${base}random/`}>let fate decide</a>.</p>
  </section>

  <div class="photo-grid" id="home-grid">
    {allItems.map((item) => (
      <RecipeCard
        title={item.title}
        image={item.image}
        href={item.href}
        description={item.description}
        tags={item.tags}
        rating={item.rating}
        category={item.category}
      />
    ))}
  </div>
</Layout>

<script>
  const grid = document.getElementById('home-grid')!;
  const cards = Array.from(grid.children);
  for (let i = cards.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    grid.appendChild(cards[j]);
    cards.splice(j, 1);
  }
</script>

<style>
  .hero {
    text-align: center;
    padding: 2rem 0 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .hero p {
    color: var(--color-muted);
    font-size: 1.1rem;
  }
</style>
