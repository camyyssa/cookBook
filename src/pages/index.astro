---
import Layout from '../layouts/Layout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const normalize = (s: string) => s.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
const recipes = await getCollection('recipes');
const inspiration = await getCollection('inspiration');
const allItems = [
  ...recipes.map((r) => ({
    id: r.id,
    title: r.data.title,
    image: r.data.image,
    description: r.data.description,
    tags: r.data.tags,
    rating: r.data.rating,
    category: r.data.tags.find((t) => ['main', 'side', 'filler'].includes(t)),
    href: `${base}recipes/${r.id}/`,
    searchText: normalize([r.data.title, ...r.data.tags, ...r.data.ingredients].join(' ')),
  })),
  ...inspiration.map((i) => ({
    id: i.id,
    title: i.data.title,
    image: i.data.image,
    description: undefined,
    tags: i.data.tags,
    rating: undefined,
    category: undefined,
    href: `${base}inspiration/`,
    searchText: normalize([i.data.title, ...i.data.tags].join(' ')),
  })),
];
---

<Layout title="Home">
  <section class="hero">
    <h1>What are we cooking today?</h1>
    <p>Browse recipes, get inspired, or <a href={`${base}random/`}>let fate decide</a>.</p>
  </section>

  <div class="search-bar">
    <input
      type="search"
      id="search"
      placeholder="Search by title, ingredient or tag…"
      autocomplete="off"
    />
  </div>

  <p id="no-results" hidden>No recipes found.</p>

  <div class="photo-grid" id="home-grid">
    {allItems.map((item) => (
      <div class="grid-item" data-search={item.searchText}>
        <RecipeCard
          title={item.title}
          image={item.image}
          href={item.href}
          description={item.description}
          tags={item.tags}
          rating={item.rating}
          category={item.category}
        />
      </div>
    ))}
  </div>
</Layout>

<script>
  // Shuffle on load
  const grid = document.getElementById('home-grid')!;
  const items = Array.from(grid.children) as HTMLElement[];
  for (let i = items.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    grid.appendChild(items[j]);
    items.splice(j, 1);
  }

  // Search
  const input = document.getElementById('search') as HTMLInputElement;
  const noResults = document.getElementById('no-results')!;

  input.addEventListener('input', () => {
    const query = input.value.trim().normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
    let visible = 0;
    document.querySelectorAll<HTMLElement>('.grid-item').forEach((item) => {
      const match = !query || item.dataset.search!.includes(query);
      item.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    noResults.hidden = visible > 0;
  });
</script>

<style>
  .hero {
    text-align: center;
    padding: 2rem 0 2rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .hero p {
    color: var(--color-muted);
    font-size: 1.1rem;
  }

  .search-bar {
    margin-bottom: 2rem;
  }

  #search {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-family: var(--font-body);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-card-bg);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s;
  }

  #search:focus {
    border-color: var(--color-accent);
  }

  #no-results {
    text-align: center;
    color: var(--color-muted);
    padding: 2rem 0;
  }
</style>
