---
import Layout from '../layouts/Layout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const recipes = await getCollection('recipes');
const inspiration = await getCollection('inspiration');
const allItems = [
  ...recipes.map((r) => ({
    id: r.id,
    title: r.data.title,
    image: r.data.image,
    description: r.data.description,
    tags: r.data.tags,
    href: `${base}recipes/${r.id}/`,
  })),
  ...inspiration.map((i) => ({
    id: i.id,
    title: i.data.title,
    image: i.data.image,
    description: undefined,
    tags: i.data.tags,
    href: `${base}inspiration/`,
  })),
];
---

<Layout title="Home">
  <section class="hero">
    <h1>What are we cooking today?</h1>
    <p>Browse recipes, get inspired, or <a href={`${base}random/`}>let fate decide</a>.</p>
  </section>

  <div class="photo-grid">
    {allItems.map((item) => (
      <RecipeCard
        title={item.title}
        image={item.image}
        href={item.href}
        description={item.description}
        tags={item.tags}
      />
    ))}
  </div>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 2rem 0 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .hero p {
    color: var(--color-muted);
    font-size: 1.1rem;
  }
</style>
